[Unit]
Description=Buckteeth API
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
User=buckteeth
Group=buckteeth
WorkingDirectory=/opt/buckteeth
EnvironmentFile=/opt/buckteeth/.env
ExecStart=/opt/buckteeth/.venv/bin/uvicorn buckteeth.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
