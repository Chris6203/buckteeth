# === Buckteeth Production Environment ===
# Copy this to .env on your server and fill in real values

# Database password (pick something strong)
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Your Anthropic API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Log level
LOG_LEVEL=INFO

# Port to expose (80 for HTTP, or 443 if you add TLS)
PORT=80
